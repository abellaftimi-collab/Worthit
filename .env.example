# Copie ce fichier en ".env" puis remplis tes clés.
# Le fichier .env ne doit JAMAIS être partagé ni commité (il est dans .gitignore).

# --- Supabase (https://supabase.com/dashboard/project/_/settings/api) ---
SUPABASE_URL=
# Clé publique (anon / publishable) — sans risque à exposer
SUPABASE_ANON_KEY=
# Clé secrète (service_role) — jamais côté navigateur, uniquement ici
SUPABASE_SERVICE_KEY=

# --- Stripe (https://dashboard.stripe.com/test/apikeys) ---
# Utilise la clé SECRÈTE de TEST (commence par sk_test_...)
STRIPE_SECRET_KEY=

# REQUIS pour que /api/webhook fonctionne (commence par whsec_...).
# Sans lui, le serveur refuse tous les webhooks : sinon n'importe qui pourrait envoyer
# un faux "paiement réussi" et s'offrir le Premium.
# En local : `stripe listen --forward-to localhost:3000/api/webhook` te le donne.
STRIPE_WEBHOOK_SECRET=

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=
# Modèle utilisé pour Worthy (gpt-4o-mini = rapide et peu coûteux)
OPENAI_MODEL=gpt-4o-mini
# Optionnel : pour viser une API compatible OpenAI (laisser vide = api.openai.com)
OPENAI_BASE_URL=

# --- Serveur ---
PORT=3000
